# Copy this file to .env and fill in the values.

# Get a free TMDB API key: https://www.themoviedb.org/settings/api
# Use the "API Read Access Token" (v4 bearer). Required for movies/TV data.
VITE_TMDB_TOKEN=

# Optional fallback: v3 API key (short one). Only needed if you don't use the token above.
VITE_TMDB_KEY=

# Optional — enables the live AI draft assistant (fantasy Draft Room).
# SERVER-SIDE ONLY: no VITE_ prefix, so it is never bundled into the browser.
# Read by api/draft-assistant.ts under `vercel dev` / on Vercel. Also add it in
# Vercel -> Settings -> Environment Variables for the deployed AI to work.
ANTHROPIC_API_KEY=
